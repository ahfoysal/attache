# Copy to .env and adjust. Native Postgres/Redis defaults for a Homebrew mac.
ATTACHE_DATABASE_URL=postgresql://apple@localhost:5432/attache
ATTACHE_REDIS_URL=redis://localhost:6379/0

# Backends. "scripted"/"heuristic" run fully offline (no API key).
# Switch to "claude"/"llm" once ANTHROPIC_API_KEY is set and extras installed.
ATTACHE_AGENT=scripted            # scripted | claude
ATTACHE_ROUTER=heuristic          # heuristic | llm

# Models (used only by the llm router / claude agent backends).
ATTACHE_ROUTER_MODEL=claude-haiku-4-5
ATTACHE_AGENT_MODEL=claude-sonnet-5

# Where task workspaces live.
ATTACHE_WORKSPACE_ROOT=~/.attache/workspaces
ATTACHE_ARTIFACT_ROOT=~/.attache/artifacts

# ANTHROPIC_API_KEY=sk-ant-...
